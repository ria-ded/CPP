# **************************************************************************** #
# 								   VARIABLES								   #
# **************************************************************************** #

NAME	= ex01
CC		= c++
FLAGS	= -Wall -Wextra -Werror -std=c++98
RM		= rm -f

# **************************************************************************** #
# 									FILES									   #
# **************************************************************************** #

SRCS	= Zombie.cpp zombieHorde.cpp main.cpp
OBJS	= $(addprefix $(OBJ_DIR)/, $(SRCS:.cpp=.o))
OBJ_DIR	= obj
HEADERS	= Zombie.hpp

# **************************************************************************** #
# 									RULES									   #
# **************************************************************************** #

all: $(NAME) 

$(NAME): $(OBJS)
	$(CC) $(FLAGS) $(OBJS) -o $(NAME)

$(OBJ_DIR)/%.o: %.cpp
	@mkdir -p $(dir $@)
	$(CC) $(FLAGS) -c $< -o $@

clean:
	$(RM) -r $(OBJ_DIR)

fclean: clean
	$(RM) $(NAME)

re: fclean all

.PHONY: all clean fclean re